# Porta e URL pública do backend (usada no redirect_uri do OAuth).
PORT=3000
BASE_URL=http://localhost:3000

# Credenciais do GitHub OAuth App.
# Crie em: GitHub > Settings > Developer settings > OAuth Apps.
# Authorization callback URL deve ser: <BASE_URL>/auth/github/callback
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
